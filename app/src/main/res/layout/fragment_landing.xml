<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/landing_pattern_overlay">

    <!-- Top Section - Logo & Branding -->
    <LinearLayout
        android:id="@+id/brandingSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="@dimen/spacing_xxl"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/featureSection"
        app:layout_constraintWidth_max="600dp">

        <!-- Logo with elegant shadow -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardCornerRadius="32dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="#FFFFFF"/>

        <!-- App Name with shadow -->
        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif-medium"
            android:shadowColor="#40000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:layout_marginBottom="@dimen/spacing_xs"/>

        <!-- Tagline -->
        <TextView
            android:id="@+id/tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tagline"
            android:textSize="@dimen/text_size_subheading"
            android:textColor="#E0F2F1"
            android:gravity="center"
            android:fontFamily="sans-serif-light"
            android:alpha="0.95"/>

    </LinearLayout>

    <!-- Feature Highlights Section -->
    <LinearLayout
        android:id="@+id/featureSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/ctaSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="600dp"/>

    <!-- Bottom Section - CTA Button -->
    <LinearLayout
        android:id="@+id/ctaSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_xl"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="600dp">

        <!-- Start Button with premium design -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonStart"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/get_started"
            android:textAllCaps="false"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:letterSpacing="0.02"
            android:focusable="true"
            android:foreground="@drawable/focus_highlight"
            app:cornerRadius="32dp"
            app:backgroundTint="#FFFFFF"
            app:elevation="12dp"
            app:strokeWidth="0dp"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="end"
            app:iconSize="24dp"
            app:iconTint="#1B5E20"
            app:iconPadding="8dp"/>

        <!-- Powered by FLIR -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/powered_by"
            android:textSize="@dimen/text_size_small"
            android:textColor="#B2DFDB"
            android:fontFamily="sans-serif-light"
            android:alpha="0.8"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
