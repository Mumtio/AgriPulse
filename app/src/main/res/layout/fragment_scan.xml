<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview Placeholder -->
    <FrameLayout
        android:id="@+id/cameraContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.flir.atlassdk.acecamerasample.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Scan Overlay Box - responsive size -->
    <View
        android:id="@+id/scanOverlay"
        android:layout_width="@dimen/scan_overlay_size"
        android:layout_height="@dimen/scan_overlay_size"
        android:background="@drawable/focus_outline"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Temperature Display -->
    <TextView
        android:id="@+id/tempText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--.- °C"
        android:textSize="@dimen/text_size_display"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="@id/scanOverlay"
        app:layout_constraintBottom_toBottomOf="@id/scanOverlay"
        app:layout_constraintStart_toStartOf="@id/scanOverlay"
        app:layout_constraintEnd_toEndOf="@id/scanOverlay"/>

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_sm"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/back_button"
            android:focusable="true"
            android:foreground="@drawable/focus_highlight"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/textScanHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xs"
            android:text="Align animal face in frame"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size_subheading"/>
    </LinearLayout>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="600dp">

        <Button
            android:id="@+id/buttonScan"
            style="@style/Widget.ACE.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_standard"
            android:maxWidth="400dp"
            android:text="SCAN"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size_heading"
            android:backgroundTint="#2E7D32"
            android:focusable="true"
            android:foreground="@drawable/focus_highlight"/>

        <Button
            android:id="@+id/buttonShare"
            style="@style/Widget.ACE.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_target_min"
            android:maxWidth="400dp"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="📤 Share with Vet"
            android:backgroundTint="#1565C0"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size_body"
            android:visibility="gone"
            android:focusable="true"
            android:foreground="@drawable/focus_highlight"/>

        <TextView
            android:id="@+id/textScanResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text=""
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size_body"
            android:gravity="center"/>

        <TextView
            android:id="@+id/textExplanation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxs"
            android:text=""
            android:textColor="#E0E0E0"
            android:textSize="@dimen/text_size_body"
            android:gravity="center"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
